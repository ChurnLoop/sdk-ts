{
  "name": "@churnloop/sdk",
  "version": "0.2.0",
  "description": "Official JavaScript / TypeScript SDK for the ChurnLoop analytics + intervention platform.",
  "license": "Apache-2.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs"
  },
  "keywords": [
    "analytics",
    "events",
    "tracking",
    "churnloop"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
